# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin login
DASHBOARD_EMAIL=seu@email.com
DASHBOARD_PASSWORD=sua-senha-forte
SESSION_SECRET=gerar-com-openssl-rand-hex-48

# Cron (gerar com: openssl rand -hex 32)
CRON_SECRET=gerar-com-openssl-rand-hex-32

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia

# Meta Ads
META_ACCESS_TOKEN=seu-token-meta

# Gmail SMTP
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=sua-app-password

# SerpAPI (Google Maps)
SERPAPI_KEY=sua-chave

# Brasil.io (prospecção CNAE)
BRASILIO_TOKEN=seu-token

# App URL
NEXT_PUBLIC_APP_URL=https://adm.upflu.digital
